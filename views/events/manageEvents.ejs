<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Events</title>
    <link rel="stylesheet" href="/css/managerEvent.css">
</head>
<body>
    <%- include('../partials/navbar') %>
    <main>
        <h1>Manage Events</h1>

        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Date</th>
                        <th>Location</th>
                        <th>Price</th>
                        <th>Tickets</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (events && events.length) { %>
                        <% events.forEach(event => { %>
                            <tr>
                                <td><%= event.title %></td>
                                <td><%= event.category %></td>
                                <td><%= event.date ? event.date.toISOString().slice(0, 10) : '' %></td>
                                <td><%= event.location %></td>
                                <td>R<%= event.ticketPrice?.toFixed(2) || '0.00' %></td>
                                <td><%= event.totalCapacity %></td>
                                <td class="action-buttons">
                                    <button type="button" class="edit-toggle" data-event-id="<%= event._id %>">Edit</button>
                                    <form action="/events/manageEvents/<%= event._id %>/delete" method="POST" onsubmit="return confirm('Delete this event?');">
                                        <button type="submit" class="delete-btn">Delete</button>
                                    </form>
                                </td>
                            </tr>
                            <tr id="edit-row-<%= event._id %>" class="hidden">
                                <td colspan="7">
                                    <form action="/events/manageEvents/<%= event._id %>/update" method="POST" class="form-card">
                                        <div class="form-row">
                                            <label>
                                                Title
                                                <input type="text" name="title" value="<%= event.title %>" required>
                                            </label>
                                            <label>
                                                Category
                                                <select name="category" required>
                                                    <option value="conference" <%= event.category === 'conference' ? 'selected' : '' %>>Conference</option>
                                                    <option value="workshop" <%= event.category === 'workshop' ? 'selected' : '' %>>Workshop</option>
                                                    <option value="festival" <%= event.category === 'festival' ? 'selected' : '' %>>Festival</option>
                                                    <option value="private" <%= event.category === 'private' ? 'selected' : '' %>>Private</option>
                                                    <option value="other" <%= event.category === 'other' ? 'selected' : '' %>>Other</option>
                                                </select>
                                            </label>
                                            <label>
                                                Date
                                                <input type="date" name="date" value="<%= event.date ? event.date.toISOString().slice(0, 10) : '' %>" required>
                                            </label>
                                        </div>
                                        <div class="form-row">
                                            <label>
                                                Location
                                                <input type="text" name="location" value="<%= event.location %>" required>
                                            </label>
                                            <label>
                                                Price
                                                <input type="number" name="price" value="<%= event.ticketPrice %>" min="0" step="0.01" required>
                                            </label>
                                            <label>
                                                Total Tickets
                                                <input type="number" name="totalCapacity" value="<%= event.totalCapacity %>" min="1" required>
                                            </label>
                                        </div>
                                        <div class="form-row" style="justify-content: flex-end;">
                                            <button type="button" class="cancel-btn" data-event-id="<%= event._id %>">Cancel</button>
                                            <button type="submit" class="save-btn">Save changes</button>
                                        </div>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" style="text-align: center; padding: 24px;">No events found.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <button type="button" id="toggle-add" class="add-btn">Add Event</button>

        <section id="add-form" class="hidden form-card">
            <h2 class="section-title">Add New Event</h2>
            <form action="/events/manageEvents/add" method="POST">
                <div class="form-row">
                    <label>
                        Title
                        <input type="text" name="title" required>
                    </label>
                    <label>
                        Category
                        <select name="category" required>
                            <option value="conference">Conference</option>
                            <option value="workshop">Workshop</option>
                            <option value="festival">Festival</option>
                            <option value="private">Private</option>
                            <option value="other">Other</option>
                        </select>
                    </label>
                    <label>
                        Date
                        <input type="date" name="date" required>
                    </label>
                </div>
                <div class="form-row">
                    <label>
                        Location
                        <input type="text" name="location" required>
                    </label>
                    <label>
                        Price
                        <input type="number" name="price" min="0" step="0.01" required>
                    </label>
                    <label>
                        Total Tickets
                        <input type="number" name="totalCapacity" min="1" required>
                    </label>
                </div>
                <input type="hidden" name="description" value="Admin created event">
                <button type="submit" class="save-btn">Create Event</button>
            </form>
        </section>
    </main>
    <%- include('../partials/footer') %>

    <script src = "/js/managerEvent.js"></script>
</body>
</html>